-- Provision the single shared editor account.
-- Both people share one login; the app supplies the email behind the scenes and
-- only ever asks for the password. Replace CHANGE_ME with the shared password
-- before running. (Committed as .example so no real password lands in git.)

do $$
declare
  uid uuid := gen_random_uuid();
  em  text := 'manifest@move.local';
  pw  text := 'CHANGE_ME';
begin
  if not exists (select 1 from auth.users where email = em) then
    insert into auth.users (
      instance_id, id, aud, role, email, encrypted_password,
      email_confirmed_at, created_at, updated_at,
      raw_app_meta_data, raw_user_meta_data,
      confirmation_token, recovery_token, email_change_token_new, email_change
    ) values (
      '00000000-0000-0000-0000-000000000000', uid, 'authenticated', 'authenticated',
      em, crypt(pw, gen_salt('bf')),
      now(), now(), now(),
      '{"provider":"email","providers":["email"]}'::jsonb, '{}'::jsonb,
      '', '', '', ''
    );

    insert into auth.identities (
      id, user_id, provider_id, identity_data, provider,
      last_sign_in_at, created_at, updated_at
    ) values (
      gen_random_uuid(), uid, uid::text,
      jsonb_build_object('sub', uid::text, 'email', em, 'email_verified', true),
      'email', now(), now(), now()
    );
  end if;
end $$;
